<% content_for(:title) { "#{@trace.task_name} — Trace" } %>

<div class="traces-show">
  <div class="traces-show__header">
    <%= link_to "← All Traces", traces_path, class: "traces-show__back" %>
    <div class="traces-show__title-row">
      <h1 class="page-title"><%= @trace.task_name %></h1>
      <span class="status-badge status-badge--<%= @trace.status %>">
        <%= @trace.status.tr("_", " ") %>
      </span>
    </div>
  </div>

  <dl class="traces-show__meta">
    <div class="traces-show__meta-item">
      <dt>Trace ID</dt>
      <dd class="mono"><%= @trace.trace_id %></dd>
    </div>
    <div class="traces-show__meta-item">
      <dt>Agent</dt>
      <dd><%= @trace.agent_id %></dd>
    </div>
    <div class="traces-show__meta-item">
      <dt>Started</dt>
      <dd><%= @trace.start_time.strftime("%Y-%m-%d %H:%M:%S UTC") %></dd>
    </div>
    <div class="traces-show__meta-item">
      <dt>Total Duration</dt>
      <dd><%= format_duration(@total_duration) %></dd>
    </div>
    <div class="traces-show__meta-item">
      <dt>Spans</dt>
      <dd><%= @spans.size %></dd>
    </div>
  </dl>

  <% if @spans.empty? %>
    <p class="traces-empty">No spans recorded for this trace.</p>
  <% else %>
    <ol class="timeline" aria-label="Span timeline">
      <% @spans.each do |span| %>
        <li class="timeline__item">
          <div class="timeline__connector">
            <span class="timeline__dot timeline__dot--<%= span.span_type %>"></span>
          </div>
          <div class="timeline__card">
            <div class="timeline__card-header">
              <span class="span-type-badge span-type-badge--<%= span.span_type %>">
                <%= span.span_type.tr("_", " ") %>
              </span>
              <span class="timeline__timestamp">
                <%= span.timestamp.strftime("%H:%M:%S.%3N") %>
              </span>
              <% latency = @span_latencies[span.span_id] %>
              <% if latency %>
                <span class="timeline__latency"><%= format_duration(latency) %> →</span>
              <% end %>
            </div>
            <% unless span.metadata.empty? %>
              <dl class="timeline__metadata">
                <% span.metadata.each do |key, value| %>
                  <div class="timeline__metadata-row">
                    <dt class="timeline__metadata-key"><%= key.to_s.tr("_", " ") %></dt>
                    <dd class="timeline__metadata-value"><%= value %></dd>
                  </div>
                <% end %>
              </dl>
            <% end %>
          </div>
        </li>
      <% end %>
    </ol>
  <% end %>
</div>
