<% content_for(:title) { "Agent Traces" } %>

<div class="traces-page">
  <div class="traces-header">
    <h1 class="page-title">Agent Traces</h1>
    <%= button_to "Generate Debug Traces", seed_traces_path, method: :post, class: "btn-seed" %>
  </div>

  <% if flash[:notice] %>
    <p class="flash flash--notice"><%= flash[:notice] %></p>
  <% end %>
  <% if flash[:alert] %>
    <p class="flash flash--alert"><%= flash[:alert] %></p>
  <% end %>

  <% if @traces.empty? %>
    <p class="traces-empty">No traces recorded yet.</p>
  <% else %>
    <table class="traces-table">
      <thead>
        <tr>
          <th>Trace ID</th>
          <th>Agent</th>
          <th>Task</th>
          <th>Start Time</th>
          <th>Duration</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @traces.each do |trace| %>
          <tr>
            <td class="traces-table__trace-id">
              <%= link_to trace.trace_id, trace_path(trace), class: "traces-table__trace-link" %>
            </td>
            <td><%= trace.agent_id %></td>
            <td><%= trace.task_name %></td>
            <td><%= trace.start_time.strftime("%Y-%m-%d %H:%M:%S UTC") %></td>
            <td><%= format_duration(trace.duration) %></td>
            <td>
              <span class="status-badge status-badge--<%= trace.status %>">
                <%= trace.status.tr("_", " ") %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
